# Optional communication channels
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=
RESEND_API_KEY=

# Supabase (for persistent data in production)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# Server-side only; set in Vercel project settings, never expose in client code.
SUPABASE_SERVICE_KEY=
# Supabase also uses the service_role naming in its dashboard. Either env name works.
SUPABASE_SERVICE_ROLE_KEY=
# Client-side anon/publishable key. Either env name works.
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Optional local fallback in development.
USE_FILE_STORE=false

# Optional AWS integrations (for production extension)
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AURAFIND_DYNAMODB_TABLE=
AURAFIND_S3_BUCKET=
AURAFIND_REKOGNITION_COLLECTION=
